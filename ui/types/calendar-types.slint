export struct WeekdayRow {
    label: [string]
}

export struct CalendarDay {
    year: int,
    month: int,
    day: int,
    is_today: bool,
    is_selected: bool,
    is_weekend: bool,
    is_current_month: bool,
    has_task: bool,
}

export struct CalendarMonth {
    year: int,
    month: int,
    days: [CalendarDay]
}
