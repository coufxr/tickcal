import { FluentTokens } from "../theme/fluent-tokens.slint";
import { IconButton } from "./common/icon-button.slint";
import { TextButton } from "./common/text-button.slint";

export component QuitDialog inherits Rectangle {
    in property <bool> is_open;

    callback minimize_to_tray();
    callback quit_app();
    callback close();

    visible: is_open;

    Rectangle {
        background: FluentTokens.overlay;

        TouchArea {
            clicked => { root.close(); }
        }
    }

    // Fluent 2 dialog: 8px corner radius
    Rectangle {
        width: 380px;
        height: 200px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: FluentTokens.neutral_bg_1;
        border-radius: FluentTokens.border_radius_large;
        border-width: 1px;
        border-color: FluentTokens.neutral_stroke_2;

        drop-shadow-color: FluentTokens.shadow_key;
        drop-shadow-blur: FluentTokens.shadow_16_blur;
        drop-shadow-offset-y: FluentTokens.shadow_16_offset;

        VerticalLayout {
            padding: 24px;
            spacing: FluentTokens.spacing_xl;

            HorizontalLayout {
                alignment: space-between;

                Text {
                    text: @tr("退出确认");
                    font-size: FluentTokens.font_size_400;
                    font-weight: FluentTokens.font_weight_semibold;
                    color: FluentTokens.neutral_fg_1;
                }

                IconButton {
                    icon: @image-url("../icons/close.svg");
                    label: @tr("关闭");
                    clicked => { root.close(); }
                }
            }

            Text {
                text: @tr("关闭窗口后，Calendar 将最小化到系统托盘继续运行。\n确定要完全退出吗？");
                font-size: FluentTokens.font_size_300;
                color: FluentTokens.neutral_fg_2;
                wrap: word-wrap;
            }

            HorizontalLayout {
                spacing: FluentTokens.spacing_s;
                alignment: end;

                TextButton {
                    label: @tr("最小化到托盘");
                    clicked => { root.minimize_to_tray(); }
                }

                TextButton {
                    label: @tr("退出");
                    is_primary: true;
                    clicked => { root.quit_app(); }
                }
            }
        }
    }
}
