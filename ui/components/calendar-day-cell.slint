export component CalendarDayCell inherits Rectangle {
    in property <int> year;
    in property <int> month;
    in property <int> day_num;
    in property <bool> is_today;
    in property <bool> is_selected;
    in property <bool> is_current_month;
    in property <bool> is_weekend;

    private property <color> today_color: #007BFF;
    private property <color> selected_color: #E6F0FF;
    private property <color> today_border_color: #60A5FA;

    border-radius: 8px;
    border-width: is_today ? 1px : 0px;
    border-color: today_border_color;
    background: is_today ? today_color : is_selected ? selected_color : transparent;

    Text {
        text: root.day_num;
        horizontal-alignment: center;
        vertical-alignment: center;
        color: is_selected && !is_today ? #FFFFFF
            : is_current_month ? is_weekend ? #D92D20 : #101828
            : #98A2B3;
    }

    TouchArea {
        clicked => { root.clicked(); }
    }

    callback clicked();
}
