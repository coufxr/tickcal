import { Fluent2Palette } from "../theme/fluent2-tokens.slint";

export component CalendarDayCell inherits Rectangle {
    in property <int> year;
    in property <int> month;
    in property <int> day_num;
    in property <bool> is_today;
    in property <bool> is_selected;
    in property <bool> is_current_month;
    in property <bool> is_weekend;

    border-radius: 4px;

    background: is_today ? Fluent2Palette.accent
        : is_selected ? Fluent2Palette.accent_light
        : is_current_month ? Fluent2Palette.surface_tile
        : transparent;

    Text {
        text: root.day_num;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-weight: is_today ? 700 : (is_current_month ? 600 : 400);
        font-size: 14px;
        color: is_today ? Fluent2Palette.text_on_accent
            : is_selected ? Fluent2Palette.accent
            : is_current_month ? (is_weekend ? Fluent2Palette.text_weekend : Fluent2Palette.text_primary)
            : Fluent2Palette.text_tertiary;
    }

    TouchArea {
        clicked => { root.clicked(); }
    }

    callback clicked();
}
