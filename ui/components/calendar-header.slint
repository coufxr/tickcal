import { Fluent2Palette } from "../theme/fluent2-tokens.slint";
import { CalendarSpacingConfig } from "../config/calendar-config.slint";

export component CalendarHeader inherits Rectangle {
    in property <int> year;
    in property <int> month;

    callback prev_month();
    callback next_month();
    callback go_today();

    height: CalendarSpacingConfig.nav_height;

    HorizontalLayout {
        spacing: CalendarSpacingConfig.nav_spacing;
        alignment: space-between;

        HorizontalLayout {
            spacing: 8px;
            alignment: start;

            Text {
                text: root.year + "年" + root.month + "月";
                font-size: 28px;
                font-weight: 700;
                color: Fluent2Palette.text_primary;
                vertical-alignment: center;
            }
        }

        HorizontalLayout {
            spacing: 8px;
            alignment: end;

            Rectangle {
                width: CalendarSpacingConfig.nav_btn_today_width;
                height: CalendarSpacingConfig.nav_btn_size;
                border-radius: 4px;
                background: Fluent2Palette.btn_bg;

                Text {
                    text: "今天";
                    font-size: 14px;
                    font-weight: 600;
                    color: Fluent2Palette.accent;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => { root.go_today(); }
                }
            }

            Rectangle {
                width: CalendarSpacingConfig.nav_btn_size;
                height: CalendarSpacingConfig.nav_btn_size;
                border-radius: 4px;
                background: Fluent2Palette.btn_bg;

                Text {
                    text: "<";
                    font-size: 16px;
                    font-weight: 700;
                    color: Fluent2Palette.text_secondary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => { root.prev_month(); }
                }
            }

            Rectangle {
                width: CalendarSpacingConfig.nav_btn_size;
                height: CalendarSpacingConfig.nav_btn_size;
                border-radius: 4px;
                background: Fluent2Palette.btn_bg;

                Text {
                    text: ">";
                    font-size: 16px;
                    font-weight: 700;
                    color: Fluent2Palette.text_secondary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => { root.next_month(); }
                }
            }
        }
    }
}
