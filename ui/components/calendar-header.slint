import { Button } from "std-widgets.slint";

export component CalendarHeader inherits Rectangle {
    in property <int> year;
    in property <int> month;

    callback prev_month();
    callback next_month();
    callback go_today();

    private property <length> content_width: 334px;

    HorizontalLayout {
        spacing: 8px;
        padding: 4px;
        min-width: root.content_width;
        preferred-width: root.content_width;
        max-width: root.content_width;

        Text {
            text: root.year + "年" + root.month + "月";
            font-size: 24px;
            font-weight: 600;
            min-width: 150px;
            vertical-alignment: center;
            horizontal-stretch: 0;
        }

        Rectangle { horizontal-stretch: 1; }

        Button {
            width: 38px;
            height: 38px;
            text: "▲";
            clicked => { root.prev_month(); }
        }

        Button {
            width: 38px;
            height: 38px;
            text: "▼";
            clicked => { root.next_month(); }
        }
    }
}
