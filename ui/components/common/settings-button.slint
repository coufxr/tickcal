import { FluentTokens } from "../../theme/fluent-tokens.slint";

export component SettingsButton inherits Rectangle {
    in property <string> text;
    in property <bool> is_selected: false;
    in property <length> btn_width: 120px;

    callback clicked();

    width: root.btn_width;
    height: 32px;
    border-radius: FluentTokens.border_radius_small;
    background: touch.pressed ? (is_selected ? FluentTokens.brand_bg_pressed : FluentTokens.neutral_bg_1_pressed) : is_selected ? FluentTokens.brand_bg : touch.has-hover ? FluentTokens.neutral_bg_3 : FluentTokens.neutral_bg_2;

    animate background { duration: 150ms; }

    Text {
        text: root.text;
        color: is_selected ? FluentTokens.neutral_fg_on_brand : FluentTokens.neutral_fg_1;
        font-size: 13px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
        mouse-cursor: pointer;
    }

    accessible-role: button;
    accessible-label: root.text;
}
