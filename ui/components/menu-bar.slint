import { Fluent2Palette } from "../theme/fluent2-tokens.slint";
import { IconButton } from "./common/icon-button.slint";

export component MenuBar inherits Rectangle {
    callback open_settings();

    height: 40px;
    background: Fluent2Palette.surface_sidebar;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        alignment: space-between;

        Text {
            text: "日历";
            font-size: 15px;
            font-weight: 600;
            color: Fluent2Palette.text_primary;
            vertical-alignment: center;
        }

        IconButton {
            icon: @image-url("../icons/settings.svg");
            label: "设置";
            clicked => { root.open_settings(); }
        }
    }
}
