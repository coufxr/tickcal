import { FluentTokens } from "../theme/fluent-tokens.slint";
import { IconButton } from "./common/icon-button.slint";

export component MenuBar inherits Rectangle {
    callback open_settings();

    height: 40px;
    background: FluentTokens.neutral_bg_1;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        alignment: space-between;

        Text {
            text: "日历";
            font-size: 15px;
            font-weight: 600;
            color: FluentTokens.neutral_fg_1;
            vertical-alignment: center;
        }

        IconButton {
            icon: @image-url("../icons/settings.svg");
            label: "设置";
            clicked => { root.open_settings(); }
        }
    }

    // 底部分割线
    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        width: 100%;
        background: FluentTokens.neutral_stroke_1;
    }
}
