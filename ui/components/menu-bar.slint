import { Fluent2Palette } from "../theme/fluent2-tokens.slint";

export component MenuBar inherits Rectangle {
    callback open_settings();

    height: 40px;
    background: Fluent2Palette.surface_sidebar;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        alignment: space-between;

        Text {
            text: "日历";
            font-size: 15px;
            font-weight: 600;
            color: Fluent2Palette.text_primary;
            vertical-alignment: center;
        }

        Rectangle {
            width: 28px;
            height: 28px;
            border-radius: 4px;
            background: settings_touch.has-hover ? Fluent2Palette.btn_hover : Fluent2Palette.btn_bg;

            Image {
                source: @image-url("../icons/settings.svg");
                width: 16px;
                height: 16px;
                colorize: Fluent2Palette.text_secondary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            settings_touch := TouchArea {
                clicked => { root.open_settings(); }
                mouse-cursor: pointer;
            }
        }
    }
}
