import { Fluent2Palette } from "../theme/fluent2-tokens.slint";

export component WeekdayLabel inherits Rectangle {
    in property <string> text;
    in property <bool> is_weekend: false;

    background: transparent;

    Text {
        text: root.text;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-weight: 400;
        font-size: 12px;
        color: root.is_weekend ? Fluent2Palette.text_weekend : Fluent2Palette.text_tertiary;
    }
}
