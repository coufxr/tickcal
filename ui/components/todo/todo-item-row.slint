import { FluentTokens } from "../../theme/fluent-tokens.slint";

export component TodoItemRow inherits Rectangle {
    in property <int> item_id;
    in property <string> item_text;
    in property <bool> item_completed;
    in property <int> row_index;

    callback toggle(int);
    callback delete(int);

    height: 44px;
    border-radius: FluentTokens.border_radius_medium;

    background: hover_area.has-hover ? FluentTokens.neutral_bg_1_hover : FluentTokens.neutral_bg_1;

    animate background { duration: 150ms; }

    hover_area := TouchArea { }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 8px;
        spacing: 12px;

        // Fluent 2 checkbox (24px)
        Rectangle {
            width: 24px;
            height: 24px;
            border-radius: FluentTokens.border_radius_small;
            border-width: 1.5px;
            border-color: root.item_completed ? FluentTokens.brand_bg : FluentTokens.neutral_stroke_1;
            background: root.item_completed ? FluentTokens.brand_bg : transparent;
            y: (parent.height - self.height) / 2;

            Image {
                source: @image-url("../../icons/check.svg");
                width: 14px;
                height: 14px;
                colorize: FluentTokens.neutral_fg_on_brand;
                visible: root.item_completed;
            }

            TouchArea {
                clicked => { root.toggle(root.item_id); }
                mouse-cursor: pointer;
            }

            accessible-role: checkbox;
            accessible-label: root.item_text;
            accessible-checked: root.item_completed;
        }

        // 文本
        Text {
            text: root.item_text;
            font-size: 14px;
            color: root.item_completed ? FluentTokens.neutral_fg_3 : FluentTokens.neutral_fg_1;
            horizontal-stretch: 1;
            vertical-alignment: center;
            overflow: elide;
        }

        // 删除按钮
        Rectangle {
            width: 28px;
            height: 28px;
            border-radius: FluentTokens.border_radius_small;
            background: del_btn.pressed ? FluentTokens.neutral_bg_1_pressed : del_btn.has-hover ? FluentTokens.neutral_bg_1_hover : transparent;
            y: (parent.height - self.height) / 2;

            Image {
                source: @image-url("../../icons/close.svg");
                width: 14px;
                height: 14px;
                colorize: FluentTokens.neutral_fg_3;
            }

            del_btn := TouchArea {
                clicked => { root.delete(root.item_id); }
                mouse-cursor: pointer;
            }

            accessible-role: button;
            accessible-label: "删除";
        }
    }
}
