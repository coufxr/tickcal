import { FluentTokens } from "../../theme/fluent-tokens.slint";

export component TodoInput inherits HorizontalLayout {
    in property <string> selected_date;
    in-out property <string> status_text;

    callback add_todo(string);

    spacing: 8px;
    height: 36px;

    Rectangle {
        horizontal-stretch: 1;
        height: 36px;
        border-radius: FluentTokens.border_radius_medium;
        border-width: 1px;
        border-color: FluentTokens.neutral_stroke_1;
        background: FluentTokens.neutral_bg_1;

        input := TextInput {
            x: 12px;
            width: parent.width - 24px;
            height: 36px;
            vertical-alignment: center;
            font-size: 14px;
            color: FluentTokens.neutral_fg_1;
            accepted => {
                if (root.selected_date == "") {
                    root.status_text = "请先选择一个日期";
                } else if (self.text != "") {
                    root.add_todo(self.text);
                    self.text = "";
                    root.status_text = "";
                }
            }

            accessible-role: text-input;
            accessible-label: "输入待办事项";
        }
    }

    Rectangle {
        width: 72px;
        height: 36px;
        border-radius: FluentTokens.border_radius_medium;
        background: add_btn.pressed ? FluentTokens.brand_bg_pressed : add_btn.has-hover ? FluentTokens.brand_bg_hover : FluentTokens.brand_bg;

        animate background { duration: 150ms; }

        Text {
            text: "添加";
            font-size: 14px;
            font-weight: 600;
            color: FluentTokens.neutral_fg_on_brand;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        add_btn := TouchArea {
            clicked => {
                if (root.selected_date == "") {
                    root.status_text = "请先选择一个日期";
                } else if (input.text == "") {
                    root.status_text = "请输入待办内容";
                } else {
                    root.add_todo(input.text);
                    input.text = "";
                    root.status_text = "";
                }
            }
            mouse-cursor: pointer;
        }

        accessible-role: button;
        accessible-label: "添加";
    }
}
