import { TaskState } from "../../globals/task-state.slint";
import { FluentTokens } from "../../theme/fluent-tokens.slint";
import { TaskInput } from "./task-input.slint";
import { TaskItemRow } from "./task-item-row.slint";

export component TaskPanel inherits Rectangle {
    background: transparent;

    VerticalLayout {
        padding: FluentTokens.spacing_xl;
        spacing: FluentTokens.spacing_m;
        alignment: start;

        // 标题
        Text {
            text: TaskState.selected_date == "" ? "请选择日期" : TaskState.selected_date + " 的待办";
            font-size: FluentTokens.font_size_500;
            font-weight: FluentTokens.font_weight_bold;
            color: FluentTokens.neutral_fg_1;
        }

        // 分割线
        Rectangle {
            height: 1px;
            background: FluentTokens.neutral_stroke_2;
        }

        // 输入区域
        TaskInput {
            selected_date: TaskState.selected_date;
            status_text <=> TaskState.status_text;
            add_task(text) => { TaskState.add_task(text); }
        }

        // 状态提示
        if TaskState.status_text != "": Rectangle {
            height: 28px;
            border-radius: FluentTokens.border_radius_small;
            background: FluentTokens.neutral_bg_2;

            Text {
                x: 12px;
                text: TaskState.status_text;
                font-size: FluentTokens.font_size_200;
                color: FluentTokens.neutral_fg_2;
                vertical-alignment: center;
            }
        }

        // Task 列表
        Flickable {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 2px;

                for item[i] in TaskState.task_items: TaskItemRow {
                    item_id: item.id;
                    item_text: item.text;
                    item_completed: item.completed;
                    row_index: i;
                    toggle(id) => { TaskState.toggle_task(id); }
                    delete(id) => { TaskState.delete_task(id); }
                }
            }
        }
    }
}
