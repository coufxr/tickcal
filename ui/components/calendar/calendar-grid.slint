import { CalendarMonth, WeekdayRow } from "../../types/calendar-types.slint";
import { FluentTokens } from "../../theme/fluent-tokens.slint";
import { CalendarSpacingConfig } from "../../config/calendar-config.slint";
import { CalendarWeekdayLabel } from "./calendar-weekday-label.slint";
import { CalendarDayCell } from "./calendar-day-cell.slint";

export component CalendarGrid inherits Rectangle {
    in property <CalendarMonth> month_data;
    in property <WeekdayRow> weekdays;
    in property <int> week_start_day;

    callback day_clicked(int, int, int);

    width: CalendarSpacingConfig.cell_size * 7 + CalendarSpacingConfig.gap * 6;
    height: CalendarSpacingConfig.header_height + 1px + CalendarSpacingConfig.header_grid_gap * 2 + CalendarSpacingConfig.cell_size * 6 + CalendarSpacingConfig.gap * 7;

    VerticalLayout {
        spacing: CalendarSpacingConfig.header_grid_gap;
        alignment: start;

        HorizontalLayout {
            spacing: CalendarSpacingConfig.gap;
            height: CalendarSpacingConfig.header_height;

            for i in 7: CalendarWeekdayLabel {
                property <int> actual_day: Math.mod(root.week_start_day + i, 7);
                horizontal-stretch: 1;
                text: weekdays.label[i];
                is_weekend: actual_day == 0 || actual_day == 6;
            }
        }

        Rectangle {
            height: 1px;
            width: 100%;
            background: FluentTokens.neutral_stroke_1;
        }

        GridLayout {
            spacing: CalendarSpacingConfig.gap;
            width: CalendarSpacingConfig.cell_size * 7 + CalendarSpacingConfig.gap * 6;
            height: CalendarSpacingConfig.cell_size * 6 + CalendarSpacingConfig.gap * 6;

            for day[idx] in month_data.days: CalendarDayCell {
                row: idx / 7;
                col: Math.mod(idx, 7);
                width: CalendarSpacingConfig.cell_size;
                height: CalendarSpacingConfig.cell_size;
                year: day.year;
                month: day.month;
                day_num: day.day;
                is_today: day.is_today;
                is_selected: day.is_selected;
                is_current_month: day.is_current_month;
                is_weekend: day.is_weekend;
                has_task: day.has_task;
                clicked => { root.day_clicked(day.year, day.month, day.day); }
            }
        }
    }
}
