import { FluentTokens } from "../../theme/fluent-tokens.slint";

export component CalendarWeekdayLabel inherits Rectangle {
    in property <string> text;
    in property <bool> is_weekend: false;

    background: transparent;

    Text {
        text: root.text;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-weight: 400;
        font-size: 12px;
        color: root.is_weekend ? FluentTokens.status_danger : FluentTokens.neutral_fg_3;
    }
}
