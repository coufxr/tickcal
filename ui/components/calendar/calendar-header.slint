import { FluentTokens } from "../../theme/fluent-tokens.slint";
import { CalendarSpacingConfig } from "../../config/calendar-config.slint";
import { NavButton } from "../common/nav-button.slint";

export component CalendarHeader inherits Rectangle {
    in property <int> year;
    in property <int> month;

    callback prev_month();
    callback next_month();
    callback go_today();

    width: CalendarSpacingConfig.cell_size * 7 + CalendarSpacingConfig.gap * 6;
    height: CalendarSpacingConfig.nav_height;

    HorizontalLayout {
        spacing: CalendarSpacingConfig.nav_spacing;
        alignment: space-between;

        // 左侧标题
        Rectangle {
            height: CalendarSpacingConfig.nav_btn_size;

            VerticalLayout {
                alignment: center;

                Text {
                    text: root.year + "年" + root.month + "月";
                    font-size: 24px;
                    font-weight: 600;
                    color: FluentTokens.neutral_fg_1;
                }
            }
        }

        // 右侧按钮
        HorizontalLayout {
            spacing: 4px;

            Rectangle {
                width: CalendarSpacingConfig.nav_btn_today_width;
                height: CalendarSpacingConfig.nav_btn_size;
                border-radius: FluentTokens.border_radius_small;
                background: today_touch.pressed ? FluentTokens.neutral_bg_1_pressed : today_touch.has-hover ? FluentTokens.neutral_bg_1_hover : FluentTokens.neutral_bg_1;

                animate background { duration: 150ms; }

                Text {
                    text: "今天";
                    font-size: 14px;
                    font-weight: 600;
                    color: FluentTokens.brand_bg;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                today_touch := TouchArea {
                    clicked => { root.go_today(); }
                    mouse-cursor: pointer;
                }

                accessible-role: button;
                accessible-label: "今天";
            }

            NavButton {
                btn_size: CalendarSpacingConfig.nav_btn_size;
                icon: @image-url("../../icons/chevron-left.svg");
                tooltip: "上一月";
                clicked => { root.prev_month(); }
            }

            NavButton {
                btn_size: CalendarSpacingConfig.nav_btn_size;
                icon: @image-url("../../icons/chevron-right.svg");
                tooltip: "下一月";
                clicked => { root.next_month(); }
            }
        }
    }
}
