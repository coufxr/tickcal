import { Fluent2Palette } from "../../theme/fluent2-tokens.slint";

export component CalendarDayCell inherits Rectangle {
    in property <int> year;
    in property <int> month;
    in property <int> day_num;
    in property <bool> is_today;
    in property <bool> is_selected;
    in property <bool> is_current_month;
    in property <bool> is_weekend;
    in property <bool> has_todo;

    border-radius: 4px;

    // 背景色逻辑（优先级从高到低）：
    // 1. 今天 → 强调色（最高视觉权重）
    // 2. 选中 → 浅强调色（用户关注的日期）
    // 3. 当月 → 灰色卡片底色（普通日期）
    // 4. 非当月 → 透明（视觉降权，暗示不可用）
    property <color> base_bg: is_today ? Fluent2Palette.accent
        : is_selected ? Fluent2Palette.accent_light
        : is_current_month ? Fluent2Palette.surface_tile
        : transparent;

    // Hover 背景色：所有日期统一使用 accent_lighter，确保一致的交互反馈
    property <color> hover_bg: Fluent2Palette.accent_lighter;

    background: touch.has-hover ? root.hover_bg : root.base_bg;

    animate background { duration: 150ms; }

    // 文字颜色逻辑：与背景色对应，确保对比度
    // - 今天：白字（在强调色背景上）
    // - 选中：强调色（在浅强调色背景上）
    // - 当月：主色（周末用红色区分）
    // - 非当月：浅灰色（视觉降权）

    Text {
        text: root.day_num;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-weight: is_today ? 700 : (is_current_month ? 600 : 400);
        font-size: 16px;
        color: is_today ? Fluent2Palette.text_on_accent
            : is_selected ? Fluent2Palette.accent
            : is_current_month ? (is_weekend ? Fluent2Palette.text_weekend : Fluent2Palette.text_primary)
            : Fluent2Palette.text_tertiary;
    }

    // 待办事项指示点：底部小圆点，今天用白点，其他用强调色
    if has_todo: Rectangle {
        width: 6px;
        height: 6px;
        border-radius: 3px;
        background: is_today ? Fluent2Palette.text_on_accent : Fluent2Palette.accent;
        x: parent.width / 2 - 3px;
        y: parent.height - 10px;
    }

    callback clicked();

    touch := TouchArea {
        clicked => { root.clicked(); }
        mouse-cursor: pointer;
    }

    accessible-role: button;
    accessible-label: root.day_num;
}
