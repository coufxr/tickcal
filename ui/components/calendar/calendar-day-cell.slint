import { FluentTokens } from "../../theme/fluent-tokens.slint";

export component CalendarDayCell inherits Rectangle {
    in property <int> year;
    in property <int> month;
    in property <int> day_num;
    in property <bool> is_today;
    in property <bool> is_selected;
    in property <bool> is_current_month;
    in property <bool> is_weekend;
    in property <bool> has_task;

    border-radius: FluentTokens.border_radius_medium;

    property <color> base_bg: is_today ? FluentTokens.brand_bg
        : is_selected ? FluentTokens.brand_bg_light
        : is_current_month ? FluentTokens.neutral_bg_1
        : transparent;

    property <color> hover_bg: FluentTokens.brand_bg_lighter;

    background: touch.has-hover ? root.hover_bg : root.base_bg;

    animate background { duration: 150ms; }

    Text {
        text: root.day_num;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-weight: is_today ? 700 : (is_current_month ? 600 : 400);
        font-size: 16px;
        color: is_today ? FluentTokens.neutral_fg_on_brand
            : is_selected ? FluentTokens.brand_bg
            : is_current_month ? (is_weekend ? FluentTokens.status_danger : FluentTokens.neutral_fg_1)
            : FluentTokens.neutral_fg_3;
    }

    if has_task: Rectangle {
        width: 6px;
        height: 6px;
        border-radius: 3px;
        background: is_today ? FluentTokens.neutral_fg_on_brand : FluentTokens.brand_bg;
        x: parent.width / 2 - 3px;
        y: parent.height - 10px;
    }

    callback clicked();

    touch := TouchArea {
        clicked => { root.clicked(); }
        mouse-cursor: pointer;
    }

    accessible-role: button;
    accessible-label: root.day_num;
}
