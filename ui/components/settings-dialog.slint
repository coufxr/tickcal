import { FluentTokens } from "../theme/fluent-tokens.slint";
import { ThemeState } from "../theme/theme-state.slint";
import { CalendarSpacingConfig, CalendarSettings } from "../config/calendar-config.slint";
import { TextButton } from "./common/text-button.slint";
import { IconButton } from "./common/icon-button.slint";

component SettingsButton inherits TextButton {
    in property <bool> is_selected: false;
    in property <length> btn_width: 120px;

    width: root.btn_width;
    is_primary: root.is_selected;
    font_size: 13px;
    border-radius: FluentTokens.border_radius_small;

    background: root.pressed
        ? (is_selected ? FluentTokens.brand_bg_pressed : FluentTokens.neutral_bg_1_pressed)
        : is_selected ? FluentTokens.brand_bg
        : root.has-hover ? FluentTokens.neutral_bg_3
        : FluentTokens.neutral_bg_2;
    border-width: 0px;
    border-color: transparent;
}

export component SettingsDialog inherits Rectangle {
    in property <bool> is_open;

    callback close();
    callback week_start_changed(int);
    callback accent_changed(int);
    callback cell_size_changed(int);
    callback dark_mode_changed(bool);

    visible: is_open;

    Rectangle {
        background: FluentTokens.overlay;

        TouchArea {
            clicked => { root.close(); }
        }
    }

    Rectangle {
        width: 420px;
        height: 480px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: FluentTokens.neutral_bg_1;
        border-radius: FluentTokens.border_radius_x_large;
        border-width: 1px;
        border-color: FluentTokens.neutral_stroke_2;

        // Fluent 2 shadow (level 16)
        drop-shadow-color: FluentTokens.shadow_key;
        drop-shadow-blur: FluentTokens.shadow_16_blur;
        drop-shadow-offset-y: FluentTokens.shadow_16_offset;

        VerticalLayout {
            padding: 24px;
            spacing: FluentTokens.spacing_xl;

            HorizontalLayout {
                alignment: space-between;

                Text {
                    text: "设置";
                    font-size: FluentTokens.font_size_500;
                    font-weight: FluentTokens.font_weight_bold;
                    color: FluentTokens.neutral_fg_1;
                }

                IconButton {
                    icon: @image-url("../icons/close.svg");
                    label: "关闭";
                    clicked => { root.close(); }
                }
            }

            VerticalLayout {
                spacing: 8px;

                Text {
                    text: "外观模式";
                    font-size: FluentTokens.font_size_300;
                    font-weight: FluentTokens.font_weight_semibold;
                    color: FluentTokens.neutral_fg_1;
                }

                HorizontalLayout {
                    spacing: 8px;

                    SettingsButton {
                        label: "浅色";
                        is_selected: !ThemeState.dark;
                        clicked => { root.dark_mode_changed(false); }
                    }

                    SettingsButton {
                        label: "深色";
                        is_selected: ThemeState.dark;
                        clicked => { root.dark_mode_changed(true); }
                    }
                }
            }

            VerticalLayout {
                spacing: 8px;

                Text {
                    text: "每周起始日";
                    font-size: FluentTokens.font_size_300;
                    font-weight: FluentTokens.font_weight_semibold;
                    color: FluentTokens.neutral_fg_1;
                }

                HorizontalLayout {
                    spacing: 8px;

                    SettingsButton {
                        label: "星期日";
                        is_selected: CalendarSettings.week_start_day == 0;
                        clicked => { root.week_start_changed(0); }
                    }

                    SettingsButton {
                        label: "星期一";
                        is_selected: CalendarSettings.week_start_day == 1;
                        clicked => { root.week_start_changed(1); }
                    }
                }
            }

            VerticalLayout {
                spacing: 8px;

                Text {
                    text: "主题色";
                    font-size: FluentTokens.font_size_300;
                    font-weight: FluentTokens.font_weight_semibold;
                    color: FluentTokens.neutral_fg_1;
                }

                for row in 2: HorizontalLayout {
                    spacing: 12px;

                    for col in 6: Rectangle {
                        property <int> color_idx: row * 6 + col;
                        visible: color_idx < FluentTokens.brand_bg_options.length;
                        width: 28px;
                        height: 28px;
                        border-radius: 14px;
                        background: color_idx < FluentTokens.brand_bg_options.length ? FluentTokens.brand_bg_options[color_idx] : transparent;
                        border-width: CalendarSettings.color_scheme_index == color_idx ? 3px : 0px;
                        border-color: CalendarSettings.color_scheme_index == color_idx ? FluentTokens.neutral_fg_1 : transparent;

                        animate border-width { duration: FluentTokens.duration_fast; }

                        TouchArea {
                            clicked => { if (color_idx < FluentTokens.brand_bg_options.length) { root.accent_changed(color_idx); } }
                            mouse-cursor: pointer;
                        }

                        accessible-role: button;
                        accessible-label: "主题色 " + (color_idx + 1);
                    }
                }
            }

            VerticalLayout {
                spacing: 8px;

                Text {
                    text: "单元格大小";
                    font-size: FluentTokens.font_size_300;
                    font-weight: FluentTokens.font_weight_semibold;
                    color: FluentTokens.neutral_fg_1;
                }

                HorizontalLayout {
                    spacing: 8px;

                    SettingsButton {
                        label: "小";
                        btn_width: 80px;
                        is_selected: CalendarSettings.cell_size_index == 0;
                        clicked => { root.cell_size_changed(0); }
                    }

                    SettingsButton {
                        label: "中";
                        btn_width: 80px;
                        is_selected: CalendarSettings.cell_size_index == 1;
                        clicked => { root.cell_size_changed(1); }
                    }

                    SettingsButton {
                        label: "大";
                        btn_width: 80px;
                        is_selected: CalendarSettings.cell_size_index == 2;
                        clicked => { root.cell_size_changed(2); }
                    }
                }
            }
        }
    }
}
