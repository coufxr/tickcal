import { Fluent2Palette } from "../theme/fluent2-tokens.slint";
import { CalendarSpacingConfig, CalendarSettings } from "../config/calendar-config.slint";
import { SettingsButton } from "./common/settings-button.slint";
import { IconButton } from "./common/icon-button.slint";

export component SettingsDialog inherits Rectangle {
    in property <bool> is_open;

    callback close();
    callback week_start_changed(int);
    callback accent_changed(int);
    callback cell_size_changed(int);
    callback dark_mode_changed(bool);

    visible: is_open;

    Rectangle {
        background: Fluent2Palette.overlay;

        TouchArea {
            clicked => { root.close(); }
        }
    }

    Rectangle {
        width: 420px;
        height: 480px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: Fluent2Palette.surface_card;
        border-radius: 8px;
        border-width: 1px;
        border-color: Fluent2Palette.border_default;

        VerticalLayout {
            padding: 24px;
            spacing: 20px;

            HorizontalLayout {
                alignment: space-between;

                Text {
                    text: "设置";
                    font-size: 20px;
                    font-weight: 700;
                    color: Fluent2Palette.text_primary;
                }

                IconButton {
                    icon: @image-url("../icons/close.svg");
                    label: "关闭";
                    clicked => { root.close(); }
                }
            }

            VerticalLayout {
                spacing: 8px;

                Text {
                    text: "外观模式";
                    font-size: 14px;
                    font-weight: 600;
                    color: Fluent2Palette.text_primary;
                }

                HorizontalLayout {
                    spacing: 8px;

                    SettingsButton {
                        text: "浅色";
                        is_selected: !Fluent2Palette.dark_mode;
                        clicked => { root.dark_mode_changed(false); }
                    }

                    SettingsButton {
                        text: "深色";
                        is_selected: Fluent2Palette.dark_mode;
                        clicked => { root.dark_mode_changed(true); }
                    }
                }
            }

            VerticalLayout {
                spacing: 8px;

                Text {
                    text: "每周起始日";
                    font-size: 14px;
                    font-weight: 600;
                    color: Fluent2Palette.text_primary;
                }

                HorizontalLayout {
                    spacing: 8px;

                    SettingsButton {
                        text: "星期日";
                        is_selected: CalendarSettings.week_start_day == 0;
                        clicked => { root.week_start_changed(0); }
                    }

                    SettingsButton {
                        text: "星期一";
                        is_selected: CalendarSettings.week_start_day == 1;
                        clicked => { root.week_start_changed(1); }
                    }
                }
            }

            VerticalLayout {
                spacing: 8px;

                Text {
                    text: "主题色";
                    font-size: 14px;
                    font-weight: 600;
                    color: Fluent2Palette.text_primary;
                }

                for row in 2: HorizontalLayout {
                    spacing: 12px;

                    for col in 6: Rectangle {
                        property <int> color_idx: row * 6 + col;
                        visible: color_idx < Fluent2Palette.accent_colors.length;
                        width: 28px;
                        height: 28px;
                        border-radius: 14px;
                        background: color_idx < Fluent2Palette.accent_colors.length ? Fluent2Palette.accent_colors[color_idx] : transparent;
                        border-width: CalendarSettings.color_scheme_index == color_idx ? 3px : 0px;
                        border-color: Fluent2Palette.text_primary;

                        animate border-width { duration: 150ms; }

                        TouchArea {
                            clicked => { if (color_idx < Fluent2Palette.accent_colors.length) { root.accent_changed(color_idx); } }
                            mouse-cursor: pointer;
                        }

                        accessible-role: button;
                        accessible-label: "主题色 " + (color_idx + 1);
                    }
                }
            }

            VerticalLayout {
                spacing: 8px;

                Text {
                    text: "单元格大小";
                    font-size: 14px;
                    font-weight: 600;
                    color: Fluent2Palette.text_primary;
                }

                HorizontalLayout {
                    spacing: 8px;

                    SettingsButton {
                        text: "小";
                        btn_width: 80px;
                        is_selected: CalendarSettings.cell_size_index == 0;
                        clicked => { root.cell_size_changed(0); }
                    }

                    SettingsButton {
                        text: "中";
                        btn_width: 80px;
                        is_selected: CalendarSettings.cell_size_index == 1;
                        clicked => { root.cell_size_changed(1); }
                    }

                    SettingsButton {
                        text: "大";
                        btn_width: 80px;
                        is_selected: CalendarSettings.cell_size_index == 2;
                        clicked => { root.cell_size_changed(2); }
                    }
                }
            }
        }
    }
}
