import { CalendarMonth, WeekdayRow } from "../types/calendar-types.slint";
import { CalendarHeader } from "./calendar-header.slint";
import { CalendarGrid } from "./calendar-grid.slint";
import { CalendarSpacingConfig } from "../config/calendar-config.slint";

export component CalendarView inherits Rectangle {
    in property <CalendarMonth> month_data;
    in property <WeekdayRow> weekdays;
    in property <int> week_start_day;

    callback prev_month();
    callback next_month();
    callback go_today();
    callback day_clicked(int, int, int);

    VerticalLayout {
        alignment: start;
        spacing: CalendarSpacingConfig.view_spacing;
        padding: CalendarSpacingConfig.view_padding;

        CalendarHeader {
            year: root.month_data.year;
            month: root.month_data.month;

            prev_month => { root.prev_month(); }
            next_month => { root.next_month(); }
            go_today => { root.go_today(); }
        }

        CalendarGrid {
            month_data: root.month_data;
            weekdays: root.weekdays;
            week_start_day: root.week_start_day;

            day_clicked(year, month, day) => { root.day_clicked(year, month, day); }
        }
    }
}
