import { Button } from "std-widgets.slint";
import { calendar_month, weekday_row } from "../types/calendar-types.slint";

export component CalendarView inherits Rectangle {
    in property <calendar_month> month_data;
    in property <weekday_row> weekdays;

    callback prev_month();
    callback next_month();
    callback go_today();
    callback day_clicked(int, int, int);

    private property <color> today_color: #007BFF;
    private property <color> selected_color: #E6F0FF;
    private property <color> today_border_color: #60A5FA;
    // 7 列日期格：46 * 7 + 间距 2 * 6 = 334
    private property <length> calendar_content_width: 334px;

    VerticalLayout {
        spacing: 8px;
        padding: 14px;

        HorizontalLayout {
            spacing: 8px;
            padding: 4px;
            min-width: root.calendar_content_width;
            preferred-width: root.calendar_content_width;
            max-width: root.calendar_content_width;

            Text {
                text: month_data.year + "年" + month_data.month + "月";
                font-size: 24px;
                font-weight: 600;
                min-width: 150px;
                vertical-alignment: center;
                horizontal-stretch: 0;
            }

            Rectangle { horizontal-stretch: 1; }

            Button {
                width: 38px;
                height: 38px;
                text: "▲";
                clicked => {
                    root.prev_month();
                }
            }

            Button {
                width: 38px;
                height: 38px;
                text: "▼";
                clicked => {
                    root.next_month();
                }
            }
        }

        GridLayout {
            spacing: 2px;
            min-width: root.calendar_content_width;
            preferred-width: root.calendar_content_width;
            max-width: root.calendar_content_width;

            for i in 7: Rectangle {
                row: 0;
                col: i;
                height: 24px;
                background: #F7F8FA;
                border-radius: 4px;

                Text {
                    text: i < weekdays.label.length ? weekdays.label[i] : "";
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    font-weight: 500;
                    color: #667085;
                }
            }

            for day[idx] in month_data.days: Rectangle {
                row: idx / 7 + 1;
                col: Math.mod(idx, 7);
                width: 46px;
                height: 46px;
                border-radius: 8px;
                border-width: day.is_today ? 1px : 0px;
                border-color: today_border_color;
                background: day.is_today ? today_color : day.is_selected ? selected_color : transparent;

                Text {
                    text: day.day;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    color: day.is_selected && !day.is_today ? #FFFFFF : day.month == month_data.month ? day.is_weekend ? #D92D20 : #101828 : #98A2B3;
                }

                TouchArea {
                    clicked => {
                        root.day_clicked(day.year, day.month, day.day);
                    }
                }
            }
        }
    }
}
