export global Fluent2Palette {
    in-out property <bool> dark_mode: false;
    in-out property <int> selected_accent_index: 0;

    // Accent color arrays (used by settings dialog for swatches)
    in-out property <[color]> accent_colors: [
        #0078D4, #0099BC, #7A7574, #767676,
        #FF8C00, #E81123, #0063B1, #6B69D6,
        #038387, #00B294, #C239B3, #9A0089
    ];

    // Light accent variants (selected day bg, selection highlight)
    in-out property <[color]> accent_light_colors: [
        #CCE4F7, #B3DAE0, #D4D2D1, #C8C8C8,
        #FFE0B2, #FEC7C7, #B3D4E8, #CBC8EF,
        #B3DFDF, #B3E8DC, #EAB3E8, #D9B3D6
    ];

    // Dark accent variants (hover)
    in-out property <[color]> accent_dark_colors: [
        #106EBE, #0087A1, #6B6A69, #686868,
        #E07E00, #CF0F20, #00589E, #5F5BBF,
        #027579, #009F84, #AF2FA1, #89007A
    ];

    // Derived accent colors (reactive to dark_mode + selected_accent_index)
    in-out property <color> accent: dark_mode ? accent_dark_colors[Math.mod(selected_accent_index, accent_dark_colors.length)] : accent_colors[Math.mod(selected_accent_index, accent_colors.length)];
    in-out property <color> accent_light: accent_light_colors[Math.mod(selected_accent_index, accent_light_colors.length)];
    in-out property <color> accent_hover: dark_mode ? accent_light_colors[Math.mod(selected_accent_index, accent_light_colors.length)] : accent_dark_colors[Math.mod(selected_accent_index, accent_dark_colors.length)];
    in-out property <color> text_on_accent: #FFFFFF;

    // Surface
    in-out property <color> surface_card: dark_mode ? #2D2D2D : #FFFFFF;
    in-out property <color> surface_tile: dark_mode ? #3C3C3C : #F2F2F2;
    in-out property <color> surface_sidebar: dark_mode ? #1F1F1F : #F5F5F5;
    in-out property <color> surface_weekday_header: dark_mode ? #333333 : #F0F0F0;
    in-out property <color> surface_window: dark_mode ? #1E1E1E : #FFFFFF;
    in-out property <color> surface_panel: dark_mode ? #252525 : #F5F5F5;

    // Text
    in-out property <color> text_primary: dark_mode ? #FFFFFF : #1B1B1B;
    in-out property <color> text_secondary: dark_mode ? #A0A0A0 : #616161;
    in-out property <color> text_tertiary: dark_mode ? #6B6B6B : #ABABAB;
    in-out property <color> text_weekend: dark_mode ? #FF6B6B : #E81123;
    in-out property <color> text_card_title: dark_mode ? #F0F0F0 : #242424;
    in-out property <color> text_weekday_weekend: dark_mode ? #FF6B6B : #D92D20;

    // Border & Divider
    in-out property <color> border_default: dark_mode ? #444444 : #E0E0E0;
    in-out property <color> divider: dark_mode ? #3A3A3A : #E0E0E0;
    in-out property <color> overlay: dark_mode ? #000000CC : #00000088;

    // Button
    in-out property <color> btn_bg: dark_mode ? #3C3C3C : #F2F2F2;
    in-out property <color> btn_hover: dark_mode ? #4A4A4A : #E5E5E5;

    // 三色交替行底色（Fluent2 标准灰色系）
    in-out property <color> row_alt_1: dark_mode ? #1E1E1E : #FFFFFF;
    in-out property <color> row_alt_2: dark_mode ? #2D2D2D : #F9F9F9;
    in-out property <color> row_alt_3: dark_mode ? #3C3C3C : #F3F3F3;
}
