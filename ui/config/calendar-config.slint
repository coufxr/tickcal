    in-out property <length> cell_size: 72px;
    in-out property <length> gap: 6px;
    in-out property <length> header_height: 40px;
    in-out property <length> header_grid_gap: 8px;
    in-out property <length> view_padding: 20px;
    in-out property <length> view_spacing: 16px;
