import { calendar_month, weekday_row } from "./types/calendar-types.slint";
import { CalendarView } from "./components/calendar-view.slint";

export component AppWindow inherits Window {
    title: "Calendar";
    preferred-width: 1120px;
    preferred-height: 760px;
    min-width: 960px;
    min-height: 640px;

    in-out property <calendar_month> month_data;
    in-out property <weekday_row> weekdays;

    callback prev_month();
    callback next_month();
    callback go_today();
    callback day_clicked(int, int, int);

    HorizontalLayout {

        CalendarView {
            month_data: root.month_data;
            weekdays: root.weekdays;

            prev_month => { root.prev_month(); }
            next_month => { root.next_month(); }
            go_today => { root.go_today(); }
            day_clicked(year, month, day) => { root.day_clicked(year, month, day); }
        }

        Rectangle {
            background: #F9FAFB;
            border-color: #EAECF0;
            border-width: 1px;
            min-width: 320px;

            VerticalLayout {
                alignment: center;

                Rectangle {
                    width: 200px;
                    height: 200px;
                    border-radius: 16px;
                    background: white;
                    border-width: 1px;
                    border-color: #E5E7EB;

                    Text {
                        text: "扩展页面";
                        font-size: 18px;
                        font-weight: 500;
                        color: #374151;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
