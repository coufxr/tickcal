import { CalendarMonth, WeekdayRow } from "./types/calendar-types.slint";
import { CalendarView } from "./components/calendar/calendar-view.slint";
import { TodoPanel } from "./components/todo/todo-panel.slint";
import { SettingsDialog } from "./components/settings-dialog.slint";
import { AboutDialog } from "./components/about-dialog.slint";
import { FluentTokens } from "./theme/fluent-tokens.slint";
import { ThemeState } from "./theme/theme-state.slint";
import {
    CalendarSettings,
    CalendarSpacingConfig,
} from "./config/calendar-config.slint";
import { TodoState } from "./globals/todo-state.slint";


export component AppWindow inherits Window {
    title: "Calendar";
    preferred-width: 1120px;
    preferred-height: 760px;
    min-width: 960px;
    min-height: 640px;
    background: FluentTokens.neutral_bg_1;

    // 月视图数据和星期标题行（由 Rust 端设置）
    in-out property <CalendarMonth> month_data;
    in-out property <WeekdayRow> weekdays;
    // 对话框状态
    in-out property <bool> settings_open: false;
    in-out property <bool> about_open: false;
    in-out property <string> app_version: "0.1.0";

    // 日历导航回调
    callback prev_month();
    callback next_month();
    callback go_today();
    callback day_clicked(int, int, int);
    callback quit();
    callback about();
    callback open_settings();
    callback week_start_changed(int);

    // 单元格大小映射：index → 像素值
    property <[length]> cell_size_values: [56px, 72px, 88px];

    // 设置持久化：Rust 端在启动时调用此回调，将保存的设置推送到 UI 全局变量
    callback apply_settings(bool, int, int, int);
    apply_settings(da, ai, ws, cs) => {
        ThemeState.dark = da;
        FluentTokens.selected_accent_index = ai;
        CalendarSettings.color_scheme_index = ai;
        CalendarSettings.week_start_day = ws;
        CalendarSettings.cell_size_index = cs;
        CalendarSpacingConfig.cell_size = root.cell_size_values[cs];
    }

    // 只读代理属性：Rust 端在窗口关闭时读取这些值并保存到磁盘
    out property <bool> persisted_dark_mode: ThemeState.dark;
    out property <int> persisted_accent_index: FluentTokens.selected_accent_index;
    out property <int> persisted_week_start_day: CalendarSettings.week_start_day;
    out property <int> persisted_cell_size_index: CalendarSettings.cell_size_index;

    // ─── 原生菜单栏 ───
    MenuBar {
        Menu {
            title: @tr("文件");
            MenuItem {
                title: @tr("设置...");
                activated => { root.open_settings(); }
            }
            MenuSeparator {}
            MenuItem {
                title: @tr("退出");
                activated => { root.quit(); }
            }
        }
        Menu {
            title: @tr("帮助");
            MenuItem {
                title: @tr("关于");
                activated => { root.about(); }
            }
        }
    }

    // ─── 窗口内容区域 ───
    VerticalLayout {
        HorizontalLayout {
            vertical-stretch: 1;

            // 左侧：日历
            Rectangle {
                width: CalendarSpacingConfig.cell_size * 7 + CalendarSpacingConfig.gap * 6 + CalendarSpacingConfig.view_padding * 2;
                background: FluentTokens.neutral_bg_1;
                horizontal-stretch: 0;

                CalendarView {
                    width: parent.width;
                    month_data: root.month_data;
                    weekdays: root.weekdays;
                    week_start_day: CalendarSettings.week_start_day;

                    prev_month => {
                        root.prev_month();
                    }
                    next_month => {
                        root.next_month();
                    }
                    go_today => {
                        root.go_today();
                    }
                    day_clicked(year, month, day) => {
                        root.day_clicked(year, month, day);
                    }
                }
            }

            // 右侧：Todo 面板
            Rectangle {
                background: FluentTokens.neutral_bg_2;
                border-width: 1px;
                border-color: FluentTokens.neutral_stroke_1;
                min-width: 320px;
                horizontal-stretch: 1;

                TodoPanel { }
            }
        }
    }

    // ─── 设置对话框 ───
    SettingsDialog {
        is_open: root.settings_open;
        close => {
            root.settings_open = false;
        }
        week_start_changed(day) => {
            CalendarSettings.week_start_day = day;
            root.week_start_changed(day);
        }
        accent_changed(idx) => {
            CalendarSettings.color_scheme_index = idx;
            FluentTokens.selected_accent_index = idx;
        }
        cell_size_changed(idx) => {
            CalendarSettings.cell_size_index = idx;
            CalendarSpacingConfig.cell_size = root.cell_size_values[idx];
        }
        dark_mode_changed(dark) => {
            ThemeState.dark = dark;
        }
    }

    // ─── 关于对话框 ───
    AboutDialog {
        is_open: root.about_open;
        version: root.app_version;
        close => { root.about_open = false; }
    }
}

export { TodoState }
