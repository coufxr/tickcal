import { calendar_month, weekday_row } from "./types/calendar-types.slint";
import { CalendarView } from "./components/calendar-view.slint";

export component AppWindow inherits Window {
    title: "Calendar";
    preferred-width: 1120px;
    preferred-height: 760px;
    min-width: 960px;
    min-height: 640px;
    background: #FFFFFF;

    in-out property <calendar_month> month_data;
    in-out property <weekday_row> weekdays;

    callback prev_month();
    callback next_month();
    callback go_today();
    callback day_clicked(int, int, int);

    HorizontalLayout {

        // 左侧：日历区域（白色 Mica 背景）
        Rectangle {
            background: #FFFFFF;
            horizontal-stretch: 1;

            CalendarView {
                month_data: root.month_data;
                weekdays: root.weekdays;

                prev_month => { root.prev_month(); }
                next_month => { root.next_month(); }
                go_today => { root.go_today(); }
                day_clicked(year, month, day) => { root.day_clicked(year, month, day); }
            }
        }

        // 右侧：扩展区域（浅灰背景）
        Rectangle {
            background: #F5F5F5;
            border-width: 1px;
            border-color: #E0E0E0;
            min-width: 320px;
            horizontal-stretch: 0;

            VerticalLayout {
                alignment: center;
                padding: 24px;

                // Fluent2 卡片风格
                Rectangle {
                    border-radius: 8px;
                    background: #FFFFFF;
                    border-width: 1px;
                    border-color: #E0E0E0;
                    height: 200px;

                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;

                        Text {
                            text: "扩展页面";
                            font-size: 18px;
                            font-weight: 600;
                            color: #242424;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        Text {
                            text: "Fluent2 风格";
                            font-size: 13px;
                            font-weight: 400;
                            color: #616161;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
