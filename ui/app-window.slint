import { calendar_month, weekday_row } from "./types/calendar-types.slint";
import { CalendarView } from "./components/calendar-view.slint";
import { MenuBar } from "./components/menu-bar.slint";
import { SettingsDialog } from "./components/settings-dialog.slint";
import { Fluent2Palette } from "./theme/fluent2-tokens.slint";
import { CalendarSettings, CalendarSpacingConfig } from "./config/calendar-config.slint";

export component AppWindow inherits Window {
    title: "Calendar";
    preferred-width: 1120px;
    preferred-height: 760px;
    min-width: 960px;
    min-height: 640px;
    background: Fluent2Palette.surface_window;

    in-out property <calendar_month> month_data;
    in-out property <weekday_row> weekdays;
    in-out property <bool> settings_open: false;

    callback prev_month();
    callback next_month();
    callback go_today();
    callback day_clicked(int, int, int);
    callback open_settings();
    callback week_start_changed(int);

    VerticalLayout {
        MenuBar {
            open_settings => { root.settings_open = true; }
        }

        HorizontalLayout {
            vertical-stretch: 1;

            Rectangle {
                background: Fluent2Palette.surface_window;
                horizontal-stretch: 1;

                CalendarView {
                    month_data: root.month_data;
                    weekdays: root.weekdays;
                    week_start_day: CalendarSettings.week_start_day;

                    prev_month => { root.prev_month(); }
                    next_month => { root.next_month(); }
                    go_today => { root.go_today(); }
                    day_clicked(year, month, day) => { root.day_clicked(year, month, day); }
                }
            }

            Rectangle {
                background: Fluent2Palette.surface_panel;
                border-width: 1px;
                border-color: Fluent2Palette.border_default;
                min-width: 320px;
                horizontal-stretch: 0;

                VerticalLayout {
                    alignment: center;
                    padding: 24px;

                    Rectangle {
                        border-radius: 8px;
                        background: Fluent2Palette.surface_card;
                        border-width: 1px;
                        border-color: Fluent2Palette.border_default;
                        height: 200px;

                        VerticalLayout {
                            alignment: center;
                            spacing: 8px;

                            Text {
                                text: "扩展页面";
                                font-size: 18px;
                                font-weight: 600;
                                color: Fluent2Palette.text_card_title;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            Text {
                                text: "Fluent2 风格";
                                font-size: 13px;
                                font-weight: 400;
                                color: Fluent2Palette.text_secondary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }

    SettingsDialog {
        is_open: root.settings_open;
        close => { root.settings_open = false; }
        week_start_changed(day) => { CalendarSettings.week_start_day = day; root.week_start_changed(day); }
        accent_changed(idx) => { CalendarSettings.color_scheme_index = idx; Fluent2Palette.selected_accent_index = idx; }
        cell_size_changed(idx) => {
            CalendarSettings.cell_size_index = idx;
            CalendarSpacingConfig.cell_size = idx == 0 ? 56px : idx == 2 ? 88px : 72px;
        }
        dark_mode_changed(dark) => { Fluent2Palette.dark_mode = dark; }
    }
}
