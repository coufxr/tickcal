import { calendar_month, weekday_row } from "./types/calendar-types.slint";
import { CalendarPage } from "./pages/calendar-page.slint";
import { PlaceholderPage } from "./pages/placeholder-page.slint";

export component AppWindow inherits Window {
    title: "Calendar";
    preferred-width: 1120px;
    preferred-height: 760px;
    min-width: 960px;
    min-height: 640px;

    in-out property <calendar_month> month_data;
    in-out property <weekday_row> weekdays;

    callback prev_month();
    callback next_month();
    callback go_today();
    callback day_clicked(int, int, int);

    HorizontalLayout {

        CalendarPage {
            min-width: 380px;
            preferred-width: 380px;
            max-width: 380px;
            month_data: root.month_data;
            weekdays: root.weekdays;

            prev_month => { root.prev_month(); }
            next_month => { root.next_month(); }
            go_today => { root.go_today(); }
            day_clicked(year, month, day) => { root.day_clicked(year, month, day); }
        }

        Rectangle {
            background: #F9FAFB;
            border-color: #EAECF0;
            border-width: 1px;
            min-width: 320px;

            PlaceholderPage {
                title: "扩展页面";
                description: "这里预留给后续功能页面，比如日程、设置、统计等。";
            }
        }
    }
}
